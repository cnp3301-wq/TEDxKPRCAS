# Supabase Configuration
# Copy this file to .env.local and fill in your values

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Email API Server (Nodemailer)
# Development: http://localhost:3001
# Production: https://your-email-server.com
VITE_EMAIL_API_URL=http://localhost:3001

# Email Configuration (for send-email server)
# Using Gmail: generate app password at https://myaccount.google.com/apppasswords
VITE_APP_EMAIL=your-email@gmail.com
VITE_APP_PASSWORD=your-app-password-here

